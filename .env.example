# Database (required – Prisma uses this)
DATABASE_URL="file:dev.sqlite"

# From Shopify Partners app dashboard or `shopify app config link`
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=read_products,write_products
SHOPIFY_APP_URL=https://your-app-host.com

# Optional: custom shop domain
# SHOP_CUSTOM_DOMAIN=

# Cron: secret for legacy /cron/update-prices (use a random string; set in production)
# CRON_SECRET=

# Debug: log per-product metafields and skip/update reasons when running price updates (set to 1 or true)
# DEBUG_METAL_PRICES=

# Billing: Premium Plan ($9.99/mo) uses test mode when NODE_ENV !== "production" (no charge).
