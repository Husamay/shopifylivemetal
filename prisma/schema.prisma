generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Session {
  id                   String    @id
  shop                 String
  state                String
  isOnline             Boolean   @default(false)
  scope                String?
  expires              DateTime?
  accessToken          String
  userId               BigInt?
  firstName            String?
  lastName             String?
  email                String?
  accountOwner         Boolean   @default(false)
  locale               String?
  collaborator         Boolean?   @default(false)
  emailVerified        Boolean?   @default(false)
  refreshToken         String?
  refreshTokenExpires   DateTime?
}

model AppSettings {
  id                 String    @id @default(cuid())
  shop               String    @unique
  metalApiKey        String?
  markupPercent      String    @default("15")
  /** manual = no auto run; daily = once per 24h; hourly = every cron run (cron runs every hour) */
  priceUpdateSchedule String   @default("daily")
  lastPriceUpdateAt  DateTime?
  /** free = manual only; premium = can use cron URL */
  plan               String    @default("free")
  /** Unique token for external cron URL; generated on install */
  cronToken          String?   @unique
  updatedAt          DateTime  @updatedAt
}

/** Idempotency: one row per webhook delivery (X-Shopify-Webhook-Id or fallback key). */
model WebhookDelivery {
  id         String   @id @default(cuid())
  deliveryId String   @unique
  topic      String
  shop       String?
  receivedAt DateTime @default(now())
}

/** Deferred work for webhooks that perform DB deletes; processed by worker/cron. */
model WebhookJob {
  id          String    @id @default(cuid())
  deliveryId  String    @unique
  topic       String
  shop        String?
  payload     String?
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  processedAt DateTime?
}
